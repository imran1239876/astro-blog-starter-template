---
import MainLayout from '../layouts/MainLayout.astro';

const services = [
  { title: "Direct Primary Care", desc: "Unlimited visits, direct access to your doctor, no insurance hassle — one flat monthly membership." },
  { title: "Women's Health", desc: "From well-woman exams to hormone therapy, care built around every stage of life." },
  { title: "Men's Health", desc: "Preventive screenings, weight management, and hormone therapy tailored for men." },
  { title: "Weight Loss Programs", desc: "Medically supervised weight loss, including GLP-1 therapy and nutrition counseling." },
  { title: "Chronic Disease Management", desc: "Ongoing care for diabetes, hypertension, thyroid disorders, and more." },
  { title: "Hormone Therapy (HRT)", desc: "Bioidentical hormone replacement for men and women, personalized to your labs." },
];

const stats = [
  { number: "$89", label: "Flat monthly membership" },
  { number: "24/7", label: "Direct access to your doctor" },
  { number: "0", label: "Insurance paperwork" },
  { number: "100%", label: "Focused on you" },
];
---
<MainLayout title="Home" description="Direct Primary Care in Illinois — unlimited access to your doctor for one flat monthly fee.">

  <style>
    .hero {
      background: linear-gradient(135deg, #0E7C7B 0%, #0A5E5D 100%);
      color: #fff;
      padding: 80px 24px;
      text-align: center;
    }
    .hero .eyebrow {
      display: inline-block;
      font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase;
      background: rgba(255,255,255,0.12); padding: 6px 14px; border-radius: 100px;
      margin-bottom: 22px; color: #D4E8E6;
    }
    .hero h1 { font-size: clamp(32px, 4.5vw, 50px); font-weight: 600; max-width: 780px; margin: 0 auto 18px; }
    .hero h1 span { color: #E9C874; }
    .hero p { font-size: 17px; color: #D4E8E6; max-width: 560px; margin: 0 auto 32px; }
    .hero-ctas { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
    .btn-gold { background: #D4A447; color: #16292B; padding: 14px 26px; border-radius: 5px; font-weight: 600; font-size: 15px; }
    .btn-gold:hover { background: #C4943A; }
    .btn-outline { border: 1px solid rgba(255,255,255,0.35); color: #fff; padding: 14px 26px; border-radius: 5px; font-weight: 600; font-size: 15px; }
    .btn-outline:hover { border-color: #fff; }

    .stats-band {
      background: #fff; border: 1px solid #E3E6E4; border-radius: 10px;
      max-width: 1000px; margin: -46px auto 0; padding: 30px 20px;
      display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px;
      box-shadow: 0 14px 30px -18px rgba(14,124,123,0.25); position: relative; z-index: 2;
    }
    .stat { text-align: center; }
    .stat .num { font-family: 'Fraunces', serif; font-size: 30px; font-weight: 700; color: #0A5E5D; }
    .stat .label { font-size: 12.5px; color: #5C6E70; margin-top: 4px; }
    @media (max-width: 700px) { .stats-band { grid-template-columns: repeat(2, 1fr); } }

    .section { max-width: 1180px; margin: 0 auto; padding: 72px 24px; }
    .section-head { max-width: 620px; margin-bottom: 40px; }
    .eyebrow-sm { font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; color: #D4A447; font-weight: 600; margin-bottom: 10px; }
    .section-head h2 { font-size: clamp(26px, 3vw, 34px); color: #0A5E5D; }
    .section-head p { color: #5C6E70; margin-top: 12px; font-size: 15.5px; }

    .services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
    .service-card { background: #fff; border: 1px solid #E3E6E4; border-radius: 8px; padding: 26px; }
    .service-card h3 { font-size: 17px; color: #0A5E5D; margin-bottom: 8px; }
    .service-card p { font-size: 14.5px; color: #5C6E70; }
    @media (max-width: 860px) { .services-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 600px) { .services-grid { grid-template-columns: 1fr; } }

    .cta-band {
      background: #16292B; color: #fff; text-align: center; padding: 56px 24px; border-radius: 12px;
      max-width: 1180px; margin: 0 auto 72px;
    }
    .cta-band h2 { font-size: clamp(24px, 3vw, 30px); margin-bottom: 12px; }
    .cta-band p { color: #C9DEDD; margin-bottom: 26px; }
  </style>

  <section class="hero">
    <span class="eyebrow">Now accepting new patients in Illinois</span>
    <h1>Healthcare that puts <span>you</span> back in the room</h1>
    <p>Unlimited access to your doctor, transparent flat-rate pricing, and zero insurance headaches — Direct Primary Care done right.</p>
    <div class="hero-ctas">
      <a href="/pricing" class="btn-gold">See Membership Pricing</a>
      <a href="/contact" class="btn-outline">Book a Visit</a>
    </div>
  </section>

  <div class="stats-band">
    {stats.map((s) => (
      <div class="stat">
        <div class="num">{s.number}</div>
        <div class="label">{s.label}</div>
      </div>
    ))}
  </div>

  <section class="section">
    <div class="section-head">
      <div class="eyebrow-sm">What we treat</div>
      <h2>Comprehensive care, all under one membership</h2>
      <p>From everyday illness to long-term hormone and weight management, our team covers it — without the insurance runaround.</p>
    </div>
    <div class="services-grid">
      {services.map((s) => (
        <div class="service-card">
          <h3>{s.title}</h3>
          <p>{s.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <div class="cta-band">
    <h2>Ready to experience healthcare done differently?</h2>
    <p>Join for $89/month — no insurance, no surprise bills, just direct access to your doctor.</p>
    <a href="/contact" class="btn-gold">Get Started</a>
  </div>

</MainLayout>
